{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "pytest: astrapi-mirror",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/bin/pytest",
            "args": [
                "${workspaceFolder}/tests",
                "-v",
                "--tb=short"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}
